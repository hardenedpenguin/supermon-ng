# DVSwitch Mode Configuration
# Copy this file to dvswitch_config.yml (or dvswitch_config_{nodeId}.yml) and customize.
#
# Security: passwords and hotspot keys must NOT appear in talkgroup rows sent to the browser.
# Define them once under `credentials`, then reference a profile with `profile` + `tg` per row.
# The UI only receives opaque smngtg1:… tokens plus friendly aliases.
#
# Optional `network` on each row (e.g. BrandMeister, TGIF): when a mode has two or more distinct
# network labels, the dashboard shows a "DMR network" (or "Network") picker before the talkgroup list.
#
# Per-node file: dvswitch_config_{nodeId}.yml overrides the global dvswitch_config.yml for that node.
# Configure abinfo_file or abinfo_port in allmon.ini for each node.
#
# --- credentials (server-side only; never returned by the API) ---
credentials:
  brandmeister:
    password: "YOUR_BM_HOTSPOT_PASSWORD"
    server: "3102.repeater.net"
    port: 62031
  tgif:
    password: "YOUR_TGIF_HOTSPOT_SECURITY_KEY"
    server: "tgif.network"
    port: 62031
  stfu:
    password: "YOUR_STFU_PASSWORD_OR_KEY"
    server: "stfu.example.net"
    port: 62031
    # Optional: override how the internal tune string is constructed.
    # Supported placeholders: {password}, {server}, {port}, {tg}
    # format: "{password}@{server}:{port}!{tg}"

# --- modes ---
modes:
  - DMR:
      talkgroups:
        # BrandMeister: `tg` is the number after ! in the hotspot connection string
        - profile: brandmeister
          tg: "91"
          alias: BM WorldWide
          network: BrandMeister
        - profile: brandmeister
          tg: "3100"
          alias: BM USA
          network: BrandMeister
        - profile: brandmeister
          tg: "3101"
          alias: BM California
          network: BrandMeister
        - profile: brandmeister
          tg: "3102"
          alias: BM Texas
          network: BrandMeister
        - profile: brandmeister
          tg: "4000"
          alias: BM Disconnect
          network: BrandMeister
        # TGIF
        - profile: tgif
          tg: "0"
          alias: TGIF Worldwide
          network: TGIF
        - profile: tgif
          tg: "1"
          alias: TGIF Local
          network: TGIF
        - profile: tgif
          tg: "2"
          alias: TGIF Regional
          network: TGIF
        - profile: tgif
          tg: "3"
          alias: TGIF National
          network: TGIF
        - profile: tgif
          tg: "4000"
          alias: TGIF Disconnect
          network: TGIF
        # BM private call example (trailing #)
        - profile: brandmeister
          tg: "310997#"
          alias: BM Parrot (private)
          network: BrandMeister
        # STFU (example)
        - profile: stfu
          tg: "91"
          alias: STFU WorldWide
          network: STFU

  - YSF:
      talkgroups:
        # YSF reflectors usually have no password; legacy `tgid` is fine (no @ in value)
        - tgid: "register.ysfreflector.de:42020"
          alias: PARROT
        - tgid: "americalink.hamfm.com:42000"
          alias: US-AMERICA-LINK
        - tgid: "ysf.kansascitywide.com:42000"
          alias: US-KCWide
        - tgid: "ysfreflector.de:42020"
          alias: YSF Reflector DE
        - tgid: "ysfreflector.com:42020"
          alias: YSF Reflector COM

  - P25:
      talkgroups:
        - tgid: "9999"
          alias: Disconnect
        - tgid: "10"
          alias: Parrot
        - tgid: "10100"
          alias: WorldWide
        - tgid: "3101"
          alias: California
        - tgid: "3102"
          alias: Texas
        - tgid: "3103"
          alias: New York
        - tgid: "3104"
          alias: Florida
        - tgid: "31010"
          alias: Alabama-Link
        - tgid: "31088"
          alias: ColoradoHD

  - DSTAR:
      talkgroups:
        - tgid: "       U"
          alias: Unlink
        - tgid: "REF001EL"
          alias: Echo (Parrot)
        - tgid: "REF004CL"
          alias: REF004C
        - tgid: "REF012CL"
          alias: REF012C
        - tgid: "REF014CL"
          alias: REF014C
        - tgid: "REF030CL"
          alias: REF030C
        - tgid: "REF038CL"
          alias: REF038C
        - tgid: "REF050CL"
          alias: REF050C
        - tgid: "REF052CL"
          alias: REF052C
        - tgid: "REF054CL"
          alias: REF054C

  - NXDN:
      talkgroups:
        - tgid: "9999"
          alias: Unlink
        - tgid: "10"
          alias: Parrot
        - tgid: "3101"
          alias: California
        - tgid: "3102"
          alias: Texas
        - tgid: "31088"
          alias: ColoradoHD

# Legacy (discouraged): full connection strings in `tgid` still work on the server file only.
# Any row whose `tgid` contains "@" is never sent to the browser; an opaque token is used instead.
# Prefer `profile` + `tg` for BM/TGIF so passwords are not stored in every talkgroup line.
