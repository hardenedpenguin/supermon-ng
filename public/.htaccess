RewriteEngine On
# RewriteBase set by scripts/configure-app-base-path.sh from APP_BASE_PATH in .env
RewriteBase /

# Hashed build assets (Vite) — safe to cache long-term
<IfModule mod_headers.c>
    <FilesMatch "^assets/.*\.(js|css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(png|jpg|jpeg|gif|webp|ico|woff2?)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

# No cache for index.html to ensure latest version is loaded
<FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Serve Vue app for non-API requests (/api and /supermon-ng/api when proxied at vhost)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !/api/
RewriteRule ^ index.html [QSA,L]

# Route API requests to PHP backend (dedicated vhost with DocumentRoot = public)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} /api/
RewriteRule ^ index.php [QSA,L]


