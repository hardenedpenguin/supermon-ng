#!/bin/sh
set -e

case "$1" in
    remove|upgrade|deconfigure)
        for unit in supermon-ng-backend supermon-ng-websocket \
            supermon-ng-database-update.service supermon-ng-node-status.service; do
            if systemctl is-active --quiet "$unit" 2>/dev/null; then
                systemctl stop "$unit" || true
            fi
        done
        for timer in supermon-ng-database-update.timer supermon-ng-node-status.timer; do
            if systemctl is-active --quiet "$timer" 2>/dev/null; then
                systemctl stop "$timer" 2>/dev/null || true
            fi
        done
        if [ "$1" = "remove" ] && command -v a2dissite >/dev/null 2>&1; then
            a2dissite -q supermon-ng 2>/dev/null || true
            if command -v apache2ctl >/dev/null 2>&1; then
                apache2ctl configtest >/dev/null 2>&1 && systemctl reload apache2 2>/dev/null || true
            fi
        fi
        ;;
esac

#DEBHELPER#

exit 0
