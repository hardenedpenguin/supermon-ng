# Application environment
APP_ENV=production
APP_DEBUG=false

# URL path prefix (install/update patches index.html + Apache from this):
#   /supermon-ng = app under main site (default)
#   /            = dedicated vhost at site root (e.g. sm.example.com)
APP_BASE_PATH=/supermon-ng

# Dedicated vhost only: hostname for Apache ServerName (install/update regenerates template)
# SUPERMON_SERVER_NAME=sm.w5gle.net

# TLS: Certbot certificate name (live dir under /etc/letsencrypt/live/NAME/); auto-detected if unset
# SSL_CERT_NAME=w5gle.net

# Filesystem paths (defaults shown)
# APP_ROOT=/var/www/html/supermon-ng
# USER_FILES_PATH=/var/www/html/supermon-ng/user_files/
# DB_PATH=database/supermon-ng.db

# Node status systemd timer interval in minutes (default 5; install/update rewrites timer unit)
# NODE_STATUS_INTERVAL_MINUTES=5
