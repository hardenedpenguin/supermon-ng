[Unit]
Description=Supermon-NG Database Auto-Update Service
After=network.target

[Service]
Type=oneshot
# Run as www-data so Monolog app-*.log and cache files match the PHP backend (supermon-ng-backend.service).
# Running as root created root-owned log files and broke API logging with "Permission denied".
User=www-data
Group=www-data
WorkingDirectory=APP_DIR_PLACEHOLDER
ExecStart=/usr/bin/php APP_DIR_PLACEHOLDER/scripts/database-auto-update.php

[Install]
WantedBy=multi-user.target

